PORT=8080
HUB_ID=hub-trial
OPENCLAW_WS_URL=
OPENCLAW_WS_CANDIDATES=
OPENCLAW_HOST=
OPENCLAW_PORT=43136
OPENCLAW_PATH=
OPENCLAW_AUTH_TOKEN=
OPENCLAW_RECONNECT_MS=2000
OPENCLAW_DISCOVERY_TIMEOUT_MS=1600
OPENCLAW_AUTO_DISCOVER=true
SETTINGS_FILE=/app/data/settings.json

PROXY_MANAGER_KIND=none
PROXY_AUTO_REGISTER=false
PROXY_MANAGER_URL=http://nginx-proxy-manager:81
PROXY_MANAGER_EMAIL=
PROXY_MANAGER_PASSWORD=
PROXY_PUBLIC_DOMAIN=
PROXY_TARGET_HOST=hub
PROXY_TARGET_PORT=8080
PROXY_TARGET_SCHEME=http
PUBLIC_BASE_URL=
HUB_ALLOWED_ORIGINS=*

DOCKER_AUTOMATION_ENABLED=true
DOCKER_AUTOMATION_AUTO_PAIR_ON_STARTUP=true
DOCKER_BIN=docker
DOCKER_COMMAND_TIMEOUT_MS=12000
OPENCLAW_DOCKER_CONTAINER_NAME=
OPENCLAW_DOCKER_CONTAINER_MATCH=openclaw
OPENCLAW_DOCKER_NETWORK=
OPENCLAW_DOCKER_WS_URL=
OPENCLAW_DOCKER_GATEWAY_PORT=43136
OPENCLAW_DOCKER_PROBE_IMAGE=ghcr.io/hostinger/hvps-openclaw:latest
OPENCLAW_DOCKER_STATE_VOLUME=hub_openclaw_state
OPENCLAW_DOCKER_ALLOW_INSECURE_PRIVATE_WS=true
OPENCLAW_DOCKER_PROBE_TIMEOUT_MS=5000
OPENCLAW_DOCKER_AUTO_APPROVE=true
